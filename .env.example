# ── 필수: Langfuse 연결 ─────────────────────────────
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ── 기본값 ──────────────────────────────────────────
DEFAULT_PROJECT=my-project
DEFAULT_ENV=prod

# ── 선택: GitHub 이슈 생성 ─────────────────────────
GITHUB_TOKEN=ghp_...
ENABLE_GITHUB_WRITE=false

# ── 선택: 자기 관찰 ────────────────────────────────
SELF_TRACE_ENABLED=false

# ── 로깅 ────────────────────────────────────────────
LOG_LEVEL=info
# NODE_ENV=development  # pretty-print 로그 (기본: JSON)

# ── 스토리지 ────────────────────────────────────────
CACHE_DB_PATH=./cache/analysis.db
